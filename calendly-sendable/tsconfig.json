{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "paths": {
      "@statflo/authentication": ["https://github.com/Statflo/titan/tree/main/packages/authentication/src/index.ts"],
      "@statflo/translate": ["https://github.com/Statflo/titan/tree/main/packages/translate/src/index.ts"],
    }
  },
  "include": ["src"],
}
